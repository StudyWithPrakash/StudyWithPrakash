        "text": "What is a Preposition?"
      },
      {
        "type": "paragraph",
        "text": "A preposition is a word that shows the relationship of a noun or pronoun with another word in the sentence."
      },
      {
        "type": "heading",
        "text": "Examples"
      },
      {
        "type": "list",
        "items": [
          "The book is on the table.",
          "Ram is in the classroom.",
          "She came from Nepal.",
          "The cat is under the chair."
        ]
      }
    ],
    "quiz": [
      {
        "question": "She is ___ the classroom.",
        "options": [
          "in",
          "on",
          "under",
          "from"
        ],
        "answer": "in"
      }
    ]
  }
]
